<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>DotNetKafkaAdapter</id>
    <version>0.1.0</version>
    <authors>DotNetKafkaAdapter Contributors</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <readme>README.md</readme>
    <projectUrl>https://github.com/javaChip56/dotnet-kafka-adapter</projectUrl>
    <description>Lightweight .NET Kafka adapter for typed publishing and consuming with DI-friendly abstractions, JSON serialization, retry handling, and optional TLS support.</description>
    <releaseNotes>Initial release with typed producer and consumer adapters, DI registration, retry and DLQ support, local Kafka development setup, and plaintext plus TLS integration tests.</releaseNotes>
    <tags>kafka dotnet messaging events integration</tags>
    <repository type="git" url="https://github.com/javaChip56/dotnet-kafka-adapter" branch="refs/heads/master" commit="e33bdd345463b2a1e0112dd8e026bbf8221e6223" />
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="Confluent.Kafka" version="2.13.2" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.DependencyInjection.Abstractions" version="10.0.3" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Hosting.Abstractions" version="10.0.3" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Options" version="10.0.3" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="D:\Research\dotnet-kafka-adapter\src\DotNetKafkaAdapter\bin\Release\net8.0\DotNetKafkaAdapter.dll" target="lib\net8.0\DotNetKafkaAdapter.dll" />
    <file src="D:\Research\dotnet-kafka-adapter\README.md" target="\README.md" />
  </files>
</package>